---
// src/components/ProjectCard.astro
const { title, image, link } = Astro.props;
---

<a href={link} target="_blank" class="m3-card">
  <md-elevation></md-elevation>
  <md-ripple></md-ripple>
  <div class="card-image-container">
    <img src={image} alt={title} loading="lazy" />
  </div>
  <div class="card-content">
    <h3>{title}</h3>
  </div>
</a>

<style>
  .m3-card { position: relative; display: flex; flex-direction: column; border-radius: 24px; background-color: var(--md-sys-color-surface-container); text-decoration: none; color: var(--md-sys-color-on-surface); overflow: hidden; transition: transform 0.2s; }
  .m3-card:hover { transform: translateY(-4px); }
  .card-image-container img { width: 100%; height: 250px; object-fit: cover; display: block; }
  .card-content { padding: 16px; text-align: center; }
  h3 { margin: 0; font-size: 1.1rem; }
</style>